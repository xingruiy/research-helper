# Optional credentials for skills/literature-survey. All APIs work without keys;
# set these only to get better rate limits. Copy to .env and fill in, or export
# them in your shell — scripts/lit_search.py reads them from the environment.

# Semantic Scholar API key (https://www.semanticscholar.org/product/api).
# Lifts the shared unauthenticated rate limit (frequent HTTP 429s without it).
S2_API_KEY=

# Contact email for OpenAlex's "polite pool" (https://docs.openalex.org).
# No signup needed — any email you own.
OPENALEX_MAILTO=
